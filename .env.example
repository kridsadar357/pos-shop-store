# --- Database (used by docker-compose, preflight, and Prisma) ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=posadmin
DB_PASSWORD=pospassword
DB_NAME=posdb

# Prisma connection string (derived from the above).
DATABASE_URL="postgresql://posadmin:pospassword@localhost:5432/posdb?schema=public"

# --- Backend ---
PORT=4000
JWT_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# --- Frontend (web/.env) ---
# VITE_API_URL=http://localhost:4000

# --- Production (docker-compose.prod.yml; see DEPLOY.md) ---
# JWT_SECRET and DB_PASSWORD above are reused. Optionally:
# APP_PORT=4000          # host port to expose the single-image app on
# CORS_ORIGIN=*          # same-origin in single-image mode, so * is fine
