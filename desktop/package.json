{
  "name": "pos-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "POS Suite desktop app (Electron) — runs the POS as a client/kiosk against a configured server",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.ttmbtech.possuite",
    "productName": "POS Suite",
    "files": ["main.js", "preload.js"],
    "extraResources": [{ "from": "../web/dist", "to": "web-dist" }],
    "mac": { "target": "dmg", "category": "public.app-category.business" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage", "category": "Office" }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
