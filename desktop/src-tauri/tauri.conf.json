{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "POS Suite",
  "version": "1.0.0",
  "identifier": "com.ttmbtech.possuite",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "POS Suite",
        "width": 1366,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
