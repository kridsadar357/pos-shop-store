generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PromptPayType {
  MSISDN // mobile number
  NATID // national / tax id
  EWALLET
}

enum MovementType {
  RECEIVE
  SALE
  RETURN
  ADJUST
  COUNT
  VOID
}

enum SaleType {
  RETAIL
  WHOLESALE
}

enum SaleStatus {
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CREDIT
}

enum PromoType {
  PERCENT // % off
  FIXED // fixed amount off
  BXGY // buy X get Y free
}

enum PromoScope {
  BILL
  PRODUCT
  CATEGORY
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  role         Role     @default(CASHIER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  sales     Sale[]          @relation("CashierSales")
  voids     Sale[]          @relation("VoidedSales")
  movements StockMovement[]
  shifts    Shift[]
}

model Setting {
  id            Int           @id @default(1)
  storeName     String        @default("My POS Store")
  address       String        @default("")
  phone         String        @default("")
  taxId         String        @default("")
  promptPayId   String        @default("")
  promptPayType PromptPayType @default(MSISDN)
  currency      String        @default("THB")
  taxRatePct    Decimal       @default(7) @db.Decimal(5, 2)
  taxInclusive  Boolean       @default(true)
  receiptFooter String        @default("Thank you!")
  // When true, attaching a member to a sale applies wholesale pricing to all lines.
  memberGetsWholesale Boolean  @default(true)
  updatedAt     DateTime      @updatedAt
}

model Member {
  id        Int      @id @default(autoincrement())
  code      String?  @unique
  name      String
  phone     String   @unique
  email     String   @default("")
  note      String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sales     Sale[]
  heldBills HeldBill[]

  @@index([name])
}

model Promotion {
  id         Int        @id @default(autoincrement())
  code       String?    @unique // optional coupon code; null = no code
  name       String
  type       PromoType
  scope      PromoScope @default(BILL)
  value      Decimal    @default(0) @db.Decimal(12, 2) // percent (0-100) or fixed amount
  buyQty     Int        @default(0) // BXGY
  getQty     Int        @default(0) // BXGY
  productId  Int? // PRODUCT scope / BXGY target
  categoryId Int? // CATEGORY scope
  minSpend   Decimal    @default(0) @db.Decimal(12, 2)
  autoApply  Boolean    @default(true) // auto vs requires coupon code
  startsAt   DateTime?
  endsAt     DateTime?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())

  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model Shift {
  id           Int       @id @default(autoincrement())
  userId       Int
  openingFloat Decimal   @default(0) @db.Decimal(12, 2)
  status       String    @default("OPEN") // OPEN | CLOSED
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  countedCash  Decimal?  @db.Decimal(12, 2)
  expectedCash Decimal?  @db.Decimal(12, 2)
  cashDiff     Decimal?  @db.Decimal(12, 2)
  note         String    @default("")

  user      User       @relation(fields: [userId], references: [id])
  sales     Sale[]
  heldBills HeldBill[]

  @@index([userId, status])
}

// A parked/held order that can be resumed and finished within the same shift.
model HeldBill {
  id         Int      @id @default(autoincrement())
  shiftId    Int
  cashierId  Int
  type       SaleType @default(RETAIL)
  memberId   Int?
  discount   Decimal  @default(0) @db.Decimal(12, 2)
  couponCode String   @default("")
  note       String   @default("")
  items      Json // [{ productId, qty }]
  createdAt  DateTime @default(now())

  shift  Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id])

  @@index([shiftId])
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  isActive   Boolean     @default(true)
  products   Product[]
  promotions Promotion[]
}

model Supplier {
  id       Int            @id @default(autoincrement())
  name     String
  phone    String         @default("")
  email    String         @default("")
  note     String         @default("")
  receipts GoodsReceipt[]
}

model Product {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  imageUrl        String?
  categoryId      Int?
  unit            String   @default("pc")
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  retailPrice     Decimal  @default(0) @db.Decimal(12, 2)
  wholesalePrice  Decimal  @default(0) @db.Decimal(12, 2)
  wholesaleMinQty Int      @default(1)
  taxRatePct      Decimal? @db.Decimal(5, 2) // null => fall back to Setting
  reorderLevel    Int      @default(0)
  stockQty        Int      @default(0) // cached balance; ledger is source of truth
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   Category?           @relation(fields: [categoryId], references: [id])
  movements  StockMovement[]
  saleItems  SaleItem[]
  grItems    GoodsReceiptItem[]
  countItems StockCountItem[]
  promotions Promotion[]

  @@index([name])
}

// The backtrack ledger: every stock change is recorded here.
model StockMovement {
  id          Int          @id @default(autoincrement())
  productId   Int
  type        MovementType
  qtyDelta    Int // signed: + adds stock, - removes
  balanceAfter Int
  unitCost    Decimal      @default(0) @db.Decimal(12, 2)
  refType     String       @default("") // "SALE" | "GOODS_RECEIPT" | "STOCK_COUNT" | "MANUAL"
  refId       Int?
  note        String       @default("")
  userId      Int?
  createdAt   DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@index([productId, createdAt])
  @@index([type, createdAt])
}

model Sale {
  id            Int           @id @default(autoincrement())
  orderNo       String        @unique
  type          SaleType      @default(RETAIL)
  status        SaleStatus    @default(PAID)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  promoDiscount Decimal       @default(0) @db.Decimal(12, 2)
  promoNames    String        @default("")
  paymentMethod PaymentMethod
  cashReceived  Decimal       @default(0) @db.Decimal(12, 2)
  changeDue     Decimal       @default(0) @db.Decimal(12, 2)
  paymentRef    String        @default("")
  qrPayload     String        @default("")
  cashierId     Int
  memberId      Int?
  shiftId       Int?
  voidedById    Int?
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())

  cashier  User       @relation("CashierSales", fields: [cashierId], references: [id])
  voidedBy User?      @relation("VoidedSales", fields: [voidedById], references: [id])
  member   Member?    @relation(fields: [memberId], references: [id])
  shift    Shift?     @relation(fields: [shiftId], references: [id])
  items    SaleItem[]

  @@index([createdAt])
  @@index([status])
}

model SaleItem {
  id            Int     @id @default(autoincrement())
  saleId        Int
  productId     Int
  nameSnapshot  String
  qty           Int
  unitPrice     Decimal @db.Decimal(12, 2)
  unitCost      Decimal @db.Decimal(12, 2)
  lineTotal     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id         Int      @id @default(autoincrement())
  refNo      String   @unique
  supplierId Int?
  note       String   @default("")
  total      Decimal  @default(0) @db.Decimal(12, 2)
  userId     Int?
  createdAt  DateTime @default(now())

  supplier Supplier?          @relation(fields: [supplierId], references: [id])
  items    GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id        Int     @id @default(autoincrement())
  receiptId Int
  productId Int
  qty       Int
  unitCost  Decimal @db.Decimal(12, 2)

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model StockCount {
  id        Int       @id @default(autoincrement())
  refNo     String    @unique
  status    String    @default("OPEN") // OPEN | POSTED
  note      String    @default("")
  userId    Int?
  createdAt DateTime  @default(now())
  postedAt  DateTime?

  items StockCountItem[]
}

model StockCountItem {
  id         Int @id @default(autoincrement())
  countId    Int
  productId  Int
  systemQty  Int
  countedQty Int

  count   StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@unique([countId, productId])
}

// Monotonic counters for human-friendly document numbers (orderNo, refNo).
model Counter {
  key   String @id
  value Int    @default(0)
}
