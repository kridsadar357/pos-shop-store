generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

enum PromptPayType {
  MSISDN // mobile number
  NATID // national / tax id
  EWALLET
}

enum MovementType {
  RECEIVE
  SALE
  RETURN
  ADJUST
  COUNT
  VOID
  TRANSFER
}

enum SaleType {
  RETAIL
  WHOLESALE
}

enum SaleStatus {
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  CREDIT
}

enum PromoType {
  PERCENT // % off
  FIXED // fixed amount off
  BXGY // buy X get Y free
}

enum PromoScope {
  BILL
  PRODUCT
  CATEGORY
}

model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  name         String
  role         Role     @default(CASHIER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  sales         Sale[]          @relation("CashierSales")
  voids         Sale[]          @relation("VoidedSales")
  movements     StockMovement[]
  shifts        Shift[]
  cashMovements CashMovement[]
}

model Setting {
  id            Int           @id @default(1)
  storeName     String        @default("My POS Store")
  address       String        @default("")
  phone         String        @default("")
  taxId         String        @default("")
  promptPayId   String        @default("")
  promptPayType PromptPayType @default(MSISDN)
  currency      String        @default("THB")
  taxRatePct    Decimal       @default(7) @db.Decimal(5, 2)
  taxInclusive  Boolean       @default(true)
  receiptFooter String        @default("Thank you!")
  // When true, attaching a member to a sale applies wholesale pricing to all lines.
  memberGetsWholesale Boolean  @default(true)

  // Receipt design
  receiptLogoUrl String?
  receiptHeader  String       @default("")
  receiptShowQR  Boolean      @default(true)  // footer PromptPay QR (with amount)

  // Printer connection
  printerType    String       @default("BROWSER")  // BROWSER | ESCPOS_NET | ESCPOS_USB
  printerAddress String       @default("")          // e.g. 192.168.1.50:9100
  printerPaper   String       @default("80mm")      // 58mm | 80mm

  // First-run setup wizard
  setupCompleted Boolean      @default(false)

  updatedAt     DateTime      @updatedAt
}

/// A store branch / location. Phase 1: sales & shifts are attributed to a branch
/// (stock balances remain central for now).
model Branch {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  name      String
  address   String   @default("")
  phone     String   @default("")
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  // Per-branch overrides (empty string = inherit the global Setting).
  promptPayId    String @default("")
  promptPayType  String @default("") // MSISDN | NATID | EWALLET
  printerType    String @default("") // BROWSER | ESCPOS_NET | ESCPOS_USB
  printerAddress String @default("")
  printerPaper   String @default("") // 58mm | 80mm
  receiptHeader  String @default("")
  receiptFooter  String @default("")

  sales         Sale[]
  shifts        Shift[]
  movements     StockMovement[]
  branchStock   BranchStock[]
  stockCounts   StockCount[]
  transfersFrom StockTransfer[] @relation("TransferFrom")
  transfersTo   StockTransfer[] @relation("TransferTo")
}

/// Licensing / 14-day demo (singleton, id = 1).
model License {
  id            Int       @id @default(1)
  key           String    @default("")
  status        String    @default("INACTIVE") // INACTIVE | DEMO | ACTIVE | EXPIRED
  plan          String    @default("")
  customer      String    @default("")
  activatedAt   DateTime?
  expiresAt     DateTime?
  demoStartedAt DateTime?
  lastCheckedAt DateTime?
  raw           String    @default("")
  updatedAt     DateTime  @updatedAt
}

model Member {
  id        Int      @id @default(autoincrement())
  code      String?  @unique
  name      String
  phone     String   @unique
  email     String   @default("")
  note      String   @default("")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  sales     Sale[]
  heldBills HeldBill[]

  @@index([name])
}

model Promotion {
  id         Int        @id @default(autoincrement())
  code       String?    @unique // optional coupon code; null = no code
  name       String
  type       PromoType
  scope      PromoScope @default(BILL)
  value      Decimal    @default(0) @db.Decimal(12, 2) // percent (0-100) or fixed amount
  buyQty     Int        @default(0) // BXGY
  getQty     Int        @default(0) // BXGY
  productId  Int? // PRODUCT scope / BXGY target
  categoryId Int? // CATEGORY scope
  minSpend   Decimal    @default(0) @db.Decimal(12, 2)
  autoApply  Boolean    @default(true) // auto vs requires coupon code
  startsAt   DateTime?
  endsAt     DateTime?
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())

  product  Product?  @relation(fields: [productId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])
}

model Shift {
  id           Int       @id @default(autoincrement())
  userId       Int
  openingFloat Decimal   @default(0) @db.Decimal(12, 2)
  status       String    @default("OPEN") // OPEN | CLOSED
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  countedCash  Decimal?  @db.Decimal(12, 2)
  expectedCash Decimal?  @db.Decimal(12, 2)
  cashDiff     Decimal?  @db.Decimal(12, 2)
  note         String    @default("")

  branchId     Int?

  user          User           @relation(fields: [userId], references: [id])
  branch        Branch?        @relation(fields: [branchId], references: [id])
  sales         Sale[]
  heldBills     HeldBill[]
  cashMovements CashMovement[]

  @@index([userId, status])
}

// Petty cash: a cash pay-in or pay-out recorded against an open shift.
// Feeds the drawer-cash reconciliation at close (expected = float + cash sales + pay-ins − pay-outs).
model CashMovement {
  id        Int      @id @default(autoincrement())
  shiftId   Int
  type      String // PAY_IN | PAY_OUT
  amount    Decimal  @db.Decimal(12, 2)
  reason    String   @default("")
  userId    Int
  createdAt DateTime @default(now())

  shift Shift @relation(fields: [shiftId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([shiftId])
}

// A parked/held order that can be resumed and finished within the same shift.
model HeldBill {
  id         Int      @id @default(autoincrement())
  shiftId    Int
  cashierId  Int
  type       SaleType @default(RETAIL)
  memberId   Int?
  discount   Decimal  @default(0) @db.Decimal(12, 2)
  couponCode String   @default("")
  note       String   @default("")
  items      Json // [{ productId, qty }]
  createdAt  DateTime @default(now())

  shift  Shift   @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  member Member? @relation(fields: [memberId], references: [id])

  @@index([shiftId])
}

model Category {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  isActive   Boolean     @default(true)
  products   Product[]
  promotions Promotion[]
}

model Supplier {
  id       Int             @id @default(autoincrement())
  name     String
  phone    String          @default("")
  email    String          @default("")
  note     String          @default("")
  receipts GoodsReceipt[]
  purchaseOrders PurchaseOrder[]
  products SupplierProduct[]
}

/// A supplier's quoted price for a product (the supplier price list).
model SupplierProduct {
  id          Int     @id @default(autoincrement())
  supplierId  Int
  productId   Int
  unitCost    Decimal @db.Decimal(12, 2)
  isPreferred Boolean @default(false)
  note        String  @default("")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
}

/// Purchase order to a supplier; receiving against it drives RECEIVE movements.
model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  refNo        String    @unique
  supplierId   Int?
  status       String    @default("DRAFT") // DRAFT | ORDERED | PARTIAL | RECEIVED | CANCELLED
  note         String    @default("")
  total        Decimal   @default(0) @db.Decimal(12, 2)
  expectedDate DateTime?
  userId       Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  supplier Supplier?           @relation(fields: [supplierId], references: [id])
  items    PurchaseOrderItem[]

  @@index([status])
}

model PurchaseOrderItem {
  id          Int     @id @default(autoincrement())
  poId        Int
  productId   Int
  qty         Int
  unitCost    Decimal @db.Decimal(12, 2)
  receivedQty Int     @default(0)

  po      PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id])
}

model Product {
  id              Int      @id @default(autoincrement())
  sku             String   @unique
  barcode         String?  @unique
  name            String
  imageUrl        String?
  categoryId      Int?
  unit            String   @default("pc")
  purchaseUnit    String   @default("") // e.g. "ลัง/box"; empty = same as base unit
  unitsPerPurchase Int     @default(1)  // base units per purchase unit (pack size)
  cost            Decimal  @default(0) @db.Decimal(12, 2)
  retailPrice     Decimal  @default(0) @db.Decimal(12, 2)
  wholesalePrice  Decimal  @default(0) @db.Decimal(12, 2)
  wholesaleMinQty Int      @default(1)
  taxRatePct      Decimal? @db.Decimal(5, 2) // null => fall back to Setting
  reorderLevel    Int      @default(0)
  stockQty        Int      @default(0) // cached balance; ledger is source of truth
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category   Category?           @relation(fields: [categoryId], references: [id])
  movements  StockMovement[]
  saleItems  SaleItem[]
  grItems    GoodsReceiptItem[]
  countItems StockCountItem[]
  promotions Promotion[]
  poItems    PurchaseOrderItem[]
  branchStock BranchStock[]
  suppliers  SupplierProduct[]

  @@index([name])
}

// The backtrack ledger: every stock change is recorded here.
model StockMovement {
  id          Int          @id @default(autoincrement())
  productId   Int
  type        MovementType
  qtyDelta    Int // signed: + adds stock, - removes
  balanceAfter Int
  unitCost    Decimal      @default(0) @db.Decimal(12, 2)
  refType     String       @default("") // "SALE" | "GOODS_RECEIPT" | "STOCK_COUNT" | "TRANSFER" | "MANUAL"
  refId       Int?
  note        String       @default("")
  userId      Int?
  branchId    Int?
  createdAt   DateTime     @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])
  branch  Branch? @relation(fields: [branchId], references: [id])

  @@index([productId, createdAt])
  @@index([type, createdAt])
  @@index([branchId])
}

/// Per-branch cached stock balance (Product.stockQty stays the all-branch total).
model BranchStock {
  id        Int @id @default(autoincrement())
  productId Int
  branchId  Int
  qty       Int @default(0)

  product Product @relation(fields: [productId], references: [id])
  branch  Branch  @relation(fields: [branchId], references: [id])

  @@unique([productId, branchId])
}

/// Inter-branch stock transfer (moves BranchStock between branches; total unchanged).
model StockTransfer {
  id           Int      @id @default(autoincrement())
  refNo        String   @unique // TR-xxxxx
  fromBranchId Int
  toBranchId   Int
  note         String   @default("")
  userId       Int?
  createdAt    DateTime @default(now())

  fromBranch Branch              @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("TransferTo", fields: [toBranchId], references: [id])
  items      StockTransferItem[]

  @@index([createdAt])
}

model StockTransferItem {
  id         Int @id @default(autoincrement())
  transferId Int
  productId  Int
  qty        Int

  transfer StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
}

model Sale {
  id            Int           @id @default(autoincrement())
  orderNo       String        @unique
  type          SaleType      @default(RETAIL)
  status        SaleStatus    @default(PAID)
  subtotal      Decimal       @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  promoDiscount Decimal       @default(0) @db.Decimal(12, 2)
  promoNames    String        @default("")
  paymentMethod PaymentMethod
  cashReceived  Decimal       @default(0) @db.Decimal(12, 2)
  changeDue     Decimal       @default(0) @db.Decimal(12, 2)
  paymentRef    String        @default("")
  qrPayload     String        @default("")
  cashierId     Int
  memberId      Int?
  shiftId       Int?
  voidedById    Int?
  voidedAt      DateTime?
  createdAt     DateTime      @default(now())

  branchId      Int?

  cashier  User       @relation("CashierSales", fields: [cashierId], references: [id])
  voidedBy User?      @relation("VoidedSales", fields: [voidedById], references: [id])
  member   Member?    @relation(fields: [memberId], references: [id])
  shift    Shift?     @relation(fields: [shiftId], references: [id])
  branch   Branch?    @relation(fields: [branchId], references: [id])
  items    SaleItem[]
  returns  Return[]

  @@index([createdAt])
  @@index([status])
}

/// A (possibly partial) refund against a paid sale; returns stock via RETURN movements.
model Return {
  id           Int           @id @default(autoincrement())
  refNo        String        @unique // RT-xxxxx
  saleId       Int
  subtotal     Decimal       @db.Decimal(12, 2)
  taxAmount    Decimal       @default(0) @db.Decimal(12, 2)
  total        Decimal       @db.Decimal(12, 2) // refund amount
  refundMethod PaymentMethod @default(CASH)
  reason       String        @default("")
  userId       Int?
  createdAt    DateTime      @default(now())

  sale  Sale         @relation(fields: [saleId], references: [id])
  items ReturnItem[]

  @@index([createdAt])
}

model ReturnItem {
  id           Int     @id @default(autoincrement())
  returnId     Int
  saleItemId   Int
  productId    Int
  nameSnapshot String
  qty          Int
  unitPrice    Decimal @db.Decimal(12, 2)
  lineTotal    Decimal @db.Decimal(12, 2)

  return Return @relation(fields: [returnId], references: [id], onDelete: Cascade)
}

model SaleItem {
  id            Int     @id @default(autoincrement())
  saleId        Int
  productId     Int
  nameSnapshot  String
  qty           Int
  unitPrice     Decimal @db.Decimal(12, 2)
  unitCost      Decimal @db.Decimal(12, 2)
  lineTotal     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model GoodsReceipt {
  id         Int      @id @default(autoincrement())
  refNo      String   @unique
  supplierId Int?
  note       String   @default("")
  total      Decimal  @default(0) @db.Decimal(12, 2)
  userId     Int?
  createdAt  DateTime @default(now())

  supplier Supplier?          @relation(fields: [supplierId], references: [id])
  items    GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id        Int     @id @default(autoincrement())
  receiptId Int
  productId Int
  qty       Int
  unitCost  Decimal @db.Decimal(12, 2)

  receipt GoodsReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id])
}

model StockCount {
  id        Int       @id @default(autoincrement())
  refNo     String    @unique
  status    String    @default("OPEN") // OPEN | POSTED
  note      String    @default("")
  userId    Int?
  branchId  Int?
  createdAt DateTime  @default(now())
  postedAt  DateTime?

  branch Branch?          @relation(fields: [branchId], references: [id])
  items  StockCountItem[]
}

model StockCountItem {
  id         Int @id @default(autoincrement())
  countId    Int
  productId  Int
  systemQty  Int
  countedQty Int

  count   StockCount @relation(fields: [countId], references: [id], onDelete: Cascade)
  product Product    @relation(fields: [productId], references: [id])

  @@unique([countId, productId])
}

// Monotonic counters for human-friendly document numbers (orderNo, refNo).
model Counter {
  key   String @id
  value Int    @default(0)
}
